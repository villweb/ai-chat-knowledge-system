{
  "name": "ai-chat-knowledge-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first core for turning AI chat records into reviewable knowledge atoms.",
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "p1:codex-import": "tsx scripts/run-manual-import-normalization.ts --source-app codex",
    "p1:rebuild-indexes": "tsx scripts/rebuild-local-indexes.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "yaml": "^2.9.0"
  }
}
